#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  sync [--project DIR] [--op-vault NAME] [--op-item NAME] [--force] [--print-source]
  sync [--template FILE] [--output FILE] [--op-vault NAME] [--op-item NAME] [--force] [--print-source]
  sync [--project DIR] [--template FILE] [--output FILE] --no-inject [--force] [--print-source]

Creates a local .env.agent from an op-injected template, locks it to mode 600,
and prints a source command without printing secret values.

Options:
  --project DIR     Project directory. Uses or creates DIR/.env.agent.tpl and writes DIR/.env.agent.
  --template FILE   Template to inject. Defaults to ../.env.agent.tpl.
  --output FILE     Output env file. Defaults to ../.env.agent.
  --op-vault NAME   1Password vault name or ID for {{PROD_PROFILE_OP_VAULT}}.
  --op-item NAME    1Password item name or ID for {{PROD_PROFILE_OP_ITEM}}.
  --no-inject       Render the template without calling op. Intended for tests.
  --force           Regenerate output even if it already exists.
  --print-source    Print shell commands suitable for eval.
  -h, --help        Show this help.
EOF
}

die() {
  printf 'sync: %s\n' "$*" >&2
  exit 1
}

validate_op_segment() {
  local name="$1"
  local value="$2"
  [[ -n "$value" ]] || die "$name is required."
  [[ "$value" != *$'\n'* && "$value" != *$'\r'* ]] || die "$name must be a single line."
  [[ "$value" != *"'"* ]] || die "$name must not contain single quotes."
  [[ "$value" != */* ]] || die "$name must not contain '/'. Use a 1Password ID if the display name is ambiguous."
}

should_skip_env_name() {
  local name="$1"
  [[ "$name" =~ ^[A-Z][A-Z0-9_]*$ ]] || return 0
  case "$name" in
    NODE_ENV|PATH|PWD|HOME|SHELL|USER|TMPDIR|TERM|PORT|DEV|PROD|CI|URL|USERNAME|PASSWORD|NOTESPLAIN) return 0 ;;
  esac
  return 1
}

append_env_name() {
  local names_file="$1"
  local name="$2"
  if should_skip_env_name "$name"; then
    return 0
  fi
  printf '%s\n' "$name" >> "$names_file"
}

discover_project_env_names() {
  local project="$1"
  local names_file="$2"
  local env_file

  for env_file in "$project"/.env.example "$project"/.env.sample "$project"/.env.defaults; do
    [[ -r "$env_file" ]] || continue
    sed -n -E 's/^[[:space:]]*(export[[:space:]]+)?([A-Za-z_][A-Za-z0-9_]*)=.*/\2/p' "$env_file" >> "$names_file"
  done

  if command -v rg >/dev/null 2>&1; then
    rg --no-heading --line-number \
      -g '!node_modules/**' \
      -g '!build/**' \
      -g '!dist/**' \
      -g '!coverage/**' \
      -g '!*.lock' \
      -g '!*.lockb' \
      -g '!package-lock.json' \
      -g '!bun.lock' \
      -g '!bun.lockb' \
      "process\\.env|import\\.meta\\.env" "$project" 2>/dev/null |
      perl -nle 'while (/(?:process\.env|import\.meta\.env)\.([A-Za-z_][A-Za-z0-9_]*)/g) { print $1 } while (/process\.env\[['\''"]([A-Za-z_][A-Za-z0-9_]*)['\''"]\]/g) { print $1 }' >> "$names_file"
  fi
}

create_project_template() {
  local project="$1"
  local target="$2"
  local names_file
  local op_names_file
  local op_item_json
  local sorted_names
  local name
  local label
  local tmp_template

  validate_op_segment "1Password vault" "$op_vault"
  validate_op_segment "1Password item" "$op_item"

  names_file="$(mktemp)"
  op_names_file="$(mktemp)"
  op_item_json="$(mktemp)"
  sorted_names="$(mktemp)"
  tmp_template="$(mktemp "$(dirname "$target")/.env.agent.tpl.tmp.XXXXXX")"

  discover_project_env_names "$project" "$names_file"

  if (( ! no_inject )); then
    command -v op >/dev/null 2>&1 || die "op CLI is required to inspect 1Password item fields."
    command -v jq >/dev/null 2>&1 || die "jq is required to inspect 1Password item fields without printing values."
    if ! op item get "$op_item" --vault "$op_vault" --format json > "$op_item_json"; then
      rm -f "$names_file" "$op_names_file" "$op_item_json" "$sorted_names" "$tmp_template"
      die "could not inspect 1Password item fields for $op_vault/$op_item."
    fi
    while IFS= read -r label; do
      append_env_name "$op_names_file" "$label"
    done < <(jq -r '.fields[]?.label // empty' "$op_item_json")
  fi

  if [[ -s "$op_names_file" ]]; then
    sort -u "$op_names_file" > "$sorted_names"
  elif [[ ! -s "$names_file" ]]; then
    append_env_name "$names_file" "DATABASE_URL"
    sort -u "$names_file" > "$sorted_names"
  else
    sort -u "$names_file" > "$sorted_names"
  fi

  {
    printf '# Generated by analyze-env/scripts/sync.\n'
    printf '# Review field names before use. Do not commit injected .env.agent files.\n\n'
    printf "PROD_PROFILE_OP_VAULT='%s'\n" "$op_vault"
    printf "PROD_PROFILE_OP_ITEM='%s'\n\n" "$op_item"
    while IFS= read -r name; do
      [[ -n "$name" ]] || continue
      if should_skip_env_name "$name"; then
        continue
      fi
      printf "%s='op://%s/%s/%s'\n" "$name" "$op_vault" "$op_item" "$name"
    done < "$sorted_names"
  } > "$tmp_template"

  chmod 600 "$tmp_template"
  mv "$tmp_template" "$target"
  rm -f "$names_file" "$op_names_file" "$op_item_json" "$sorted_names"
}

render_template() {
  local source_file="$1"
  local rendered_file="$2"
  local needs_vault=0
  local needs_item=0
  local line

  grep -q '{{PROD_PROFILE_OP_VAULT}}' "$source_file" && needs_vault=1
  grep -q '{{PROD_PROFILE_OP_ITEM}}' "$source_file" && needs_item=1

  if (( needs_vault )); then
    validate_op_segment "1Password vault" "$op_vault"
  fi

  if (( needs_item )); then
    validate_op_segment "1Password item" "$op_item"
  fi

  : > "$rendered_file"
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line//\{\{PROD_PROFILE_OP_VAULT\}\}/$op_vault}"
    line="${line//\{\{PROD_PROFILE_OP_ITEM\}\}/$op_item}"
    printf '%s\n' "$line" >> "$rendered_file"
  done < "$source_file"
}

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
skill_dir="$(cd "$script_dir/.." && pwd)"
project_dir=''
template=''
output=''
template_set=0
output_set=0
op_vault="${PROD_PROFILE_OP_VAULT:-}"
op_item="${PROD_PROFILE_OP_ITEM:-}"
no_inject=0
force=0
print_source=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --project)
      [[ $# -ge 2 ]] || die "--project requires a directory."
      [[ -d "$2" ]] || die "project directory does not exist: $2"
      project_dir="$(cd "$2" && pwd)"
      shift 2
      ;;
    --template)
      [[ $# -ge 2 ]] || die "--template requires a file path."
      template="$2"
      template_set=1
      shift 2
      ;;
    --output)
      [[ $# -ge 2 ]] || die "--output requires a file path."
      output="$2"
      output_set=1
      shift 2
      ;;
    --op-vault)
      [[ $# -ge 2 ]] || die "--op-vault requires a value."
      op_vault="$2"
      shift 2
      ;;
    --op-item)
      [[ $# -ge 2 ]] || die "--op-item requires a value."
      op_item="$2"
      shift 2
      ;;
    --no-inject)
      no_inject=1
      shift
      ;;
    --force)
      force=1
      shift
      ;;
    --print-source)
      print_source=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
done

if [[ -n "$project_dir" ]]; then
  if (( ! template_set )); then
    template="$project_dir/.env.agent.tpl"
  fi
  if (( ! output_set )); then
    output="$project_dir/.env.agent"
  fi
else
  if (( ! template_set )); then
    template="$skill_dir/.env.agent.tpl"
  fi
  if (( ! output_set )); then
    output="$skill_dir/.env.agent"
  fi
fi

if [[ -e "$output" && "$force" -eq 0 ]]; then
  [[ -f "$output" ]] || die "output exists but is not a regular file: $output"
  chmod 600 "$output"
else
  if [[ ! -e "$template" && -n "$project_dir" ]]; then
    create_project_template "$project_dir" "$template"
  fi
  [[ -r "$template" ]] || die "cannot read template: $template"
  mkdir -p "$(dirname "$output")"
  rendered_template="$(mktemp)"
  tmp_output="$(mktemp "$(dirname "$output")/.env.agent.tmp.XXXXXX")"
  trap 'rm -f "$rendered_template" "$tmp_output"' EXIT
  render_template "$template" "$rendered_template"
  if (( no_inject )); then
    cp "$rendered_template" "$tmp_output"
  else
    command -v op >/dev/null 2>&1 || die "op CLI is required to inject $template. Provide .env.agent or already-exported env vars instead."
    op inject -i "$rendered_template" -o "$tmp_output" --force
  fi
  chmod 600 "$tmp_output"
  mv "$tmp_output" "$output"
fi

if (( print_source )); then
  printf 'set -a\n'
  printf '. %q\n' "$output"
  printf 'set +a\n'
else
  printf 'Prepared agent env: %s\n' "$output"
  printf 'Load it in the current shell with:\n'
  printf '  set -a; . %q; set +a\n' "$output"
fi
